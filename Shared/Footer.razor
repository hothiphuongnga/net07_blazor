@namespace buoi18.Shared

<footer class="bg-dark text-light mt-5">
    <h6>demo</h6>
    <div class="container py-4">
        <div class="row gy-4">
            <div class="col-12 col-md-4">
                <h5 class="fw-bold text-info">My Blazor App</h5>

                <p class="text-secondary mb-0">
                    Website được xây dựng bằng Blazor và Bootstrap 5.
                </p>
            </div>

            <div class="col-6 col-md-4">
                <h6 class="fw-bold">Liên kết</h6>

                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <a href="/" class="text-decoration-none text-secondary">
                            Trang chủ
                        </a>
                    </li>

                    <li class="mb-2">
                        <a href="/about" class="text-decoration-none text-secondary">
                            Giới thiệu
                        </a>
                    </li>

                    <li>
                        <a href="/contact" class="text-decoration-none text-secondary">
                            Liên hệ
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-6 col-md-4">
                <h6 class="fw-bold">Thông tin liên hệ</h6>

                <p class="text-secondary mb-2">
                    Email: contact@example.com
                </p>

                <p class="text-secondary mb-0">
                    Điện thoại: 0123 456 789
                </p>
            </div>
        </div>
    </div>

    <div class="border-top border-secondary">
        <div class="container py-3 text-center">
            <small class="text-secondary">
                © @CurrentYear My Blazor App. All rights reserved.
            </small>
        </div>
    </div>
</footer>

@code {
    private int CurrentYear => DateTime.Now.Year;
}